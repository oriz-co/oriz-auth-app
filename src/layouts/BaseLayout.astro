---
import '~/styles/global.css'

interface Props {
  title?: string
  description?: string
}
const {
  title = 'Sign in · oriz',
  description = 'Sign in to your oriz account.',
} = Astro.props
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={`https://auth.oriz.in${Astro.url.pathname}`} />
    <meta name="theme-color" content="#2f4f3a" />
    <meta name="referrer" content="no-referrer" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Ccircle cx='16' cy='16' r='14' fill='%232f4f3a'/%3E%3Ctext x='16' y='22' text-anchor='middle' fill='%23faf6ef' font-family='Georgia,serif' font-size='18'%3Eo%3C/text%3E%3C/svg%3E" />
  </head>
  <body>
    <div class="shell">
      <main class="center">
        <slot />
      </main>
      <footer class="site">
        <div>
          <a href="https://oriz.in">oriz.in</a> ·
          <a href="https://oriz.in/legal/privacy">Privacy</a> ·
          <a href="https://oriz.in/legal/terms">Terms</a> ·
          <a href="https://status.oriz.in">Status</a>
        </div>
        <div class="tiny" style="margin-top:0.4rem;">© oriz · central auth surface</div>
      </footer>
    </div>
  </body>
</html>
