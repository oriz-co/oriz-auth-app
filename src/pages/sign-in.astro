---
import BaseLayout from '~/layouts/BaseLayout.astro'
import Brand from '~/components/Brand.astro'
---
<BaseLayout title="Sign in · oriz">
  <section class="card">
    <Brand />
    <h1>Welcome back</h1>
    <p class="sub">Sign in to continue to oriz.</p>

    <div class="stack">
      <button class="btn" data-provider="google" type="button">
        <svg class="icon" viewBox="0 0 18 18" aria-hidden="true"><path fill="#4285F4" d="M17.64 9.2c0-.64-.06-1.25-.16-1.84H9v3.49h4.84a4.14 4.14 0 0 1-1.8 2.71v2.26h2.92a8.78 8.78 0 0 0 2.68-6.62z"/><path fill="#34A853" d="M9 18c2.43 0 4.47-.8 5.96-2.18l-2.92-2.26c-.8.54-1.84.86-3.04.86-2.34 0-4.32-1.58-5.03-3.7H.96v2.32A9 9 0 0 0 9 18z"/><path fill="#FBBC05" d="M3.97 10.72A5.4 5.4 0 0 1 3.68 9c0-.6.1-1.18.29-1.72V4.96H.96A9 9 0 0 0 0 9c0 1.45.35 2.83.96 4.04l3.01-2.32z"/><path fill="#EA4335" d="M9 3.58c1.32 0 2.5.45 3.44 1.35l2.58-2.58A9 9 0 0 0 9 0 9 9 0 0 0 .96 4.96l3.01 2.32C4.68 5.16 6.66 3.58 9 3.58z"/></svg>
        <span class="label">Continue with Google</span>
      </button>

      <button class="btn" data-provider="github" type="button">
        <svg class="icon" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor"><path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56v-2.03c-3.2.7-3.87-1.36-3.87-1.36-.52-1.32-1.28-1.67-1.28-1.67-1.04-.71.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.36.97.1-.74.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.28 1.19-3.09-.12-.29-.52-1.46.11-3.04 0 0 .97-.31 3.19 1.18a11 11 0 0 1 5.81 0c2.21-1.49 3.18-1.18 3.18-1.18.63 1.58.23 2.75.11 3.04.74.81 1.19 1.83 1.19 3.09 0 4.42-2.69 5.39-5.26 5.68.41.36.78 1.06.78 2.13v3.16c0 .31.21.67.8.56C20.21 21.38 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"/></svg>
        <span class="label">Continue with GitHub</span>
      </button>

      <button class="btn" data-provider="microsoft" type="button">
        <svg class="icon" viewBox="0 0 23 23" aria-hidden="true"><path fill="#f25022" d="M0 0h11v11H0z"/><path fill="#7fba00" d="M12 0h11v11H12z"/><path fill="#00a4ef" d="M0 12h11v11H0z"/><path fill="#ffb900" d="M12 12h11v11H12z"/></svg>
        <span class="label">Continue with Microsoft</span>
      </button>
    </div>

    <div class="divider">or</div>

    <form id="email-form" class="stack" novalidate>
      <div class="field">
        <label for="email">Email</label>
        <input id="email" type="email" autocomplete="email" required placeholder="you@oriz.in" />
      </div>
      <button class="btn btn-primary" type="submit" data-action="email-link">
        <span class="label">Send sign-in link</span>
      </button>
    </form>

    <div class="more">
      <button id="more-btn" type="button">More sign-in options</button>
      <div class="gated" id="gated">
        <div class="divider">Phone</div>
        <form id="phone-form" class="stack" novalidate>
          <div class="field">
            <label for="phone">Phone (with country code)</label>
            <input id="phone" type="tel" autocomplete="tel" placeholder="+91 98765 43210" />
          </div>
          <div id="recaptcha-container"></div>
          <button class="btn" type="submit" data-action="phone-otp">
            <span class="label">Send OTP</span>
          </button>
          <p class="tiny">Phone is reserved for Pro+ subscribers. Free-tier users: use email or social.</p>
        </form>
      </div>
    </div>

    <div id="banner" class="banner" data-kind="info"></div>

    <p class="muted center-text" style="margin-top:1.5rem;">
      New here? Any sign-in creates your account automatically.
    </p>
  </section>

  <script>
    import {
      GoogleAuthProvider,
      GithubAuthProvider,
      OAuthProvider,
      signInWithPopup,
      sendSignInLinkToEmail,
      RecaptchaVerifier,
      signInWithPhoneNumber,
      type ConfirmationResult,
    } from 'firebase/auth'
    import { getFirebase, startCookieSync, safeReturnURL } from '~/lib/firebase'

    const { auth } = getFirebase()
    startCookieSync()

    const params = new URLSearchParams(window.location.search)
    const ret = params.get('return') || params.get('returnTo') || '/account'
    const phoneFlag = params.get('phone') === '1'

    const banner = document.getElementById('banner') as HTMLDivElement
    const show = (msg: string, kind: 'info' | 'error' | 'success' = 'info') => {
      banner.textContent = msg
      banner.dataset.kind = kind
      banner.style.display = 'block'
    }
    const clear = () => { banner.style.display = 'none'; banner.textContent = '' }

    // Already signed in? Bounce straight to return URL.
    auth.onAuthStateChanged((user) => {
      if (user) window.location.replace(safeReturnURL(ret))
    })

    // OAuth popup flow
    async function oauth(name: 'google' | 'github' | 'microsoft') {
      clear()
      try {
        let provider
        if (name === 'google') provider = new GoogleAuthProvider()
        else if (name === 'github') {
          provider = new GithubAuthProvider()
          provider.addScope('read:user')
        } else {
          provider = new OAuthProvider('microsoft.com')
        }
        await signInWithPopup(auth, provider)
        // onAuthStateChanged will redirect
      } catch (err) {
        const e = err as { code?: string; message?: string }
        if (e.code === 'auth/popup-closed-by-user') return
        show(e.message ?? 'Sign-in failed.', 'error')
      }
    }

    document.querySelectorAll<HTMLButtonElement>('[data-provider]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const name = btn.dataset.provider as 'google' | 'github' | 'microsoft'
        oauth(name)
      })
    })

    // Email magic link
    const emailForm = document.getElementById('email-form') as HTMLFormElement
    emailForm.addEventListener('submit', async (e) => {
      e.preventDefault()
      clear()
      const email = (document.getElementById('email') as HTMLInputElement).value.trim()
      if (!email) return show('Enter your email.', 'error')
      const url = new URL('/finish-sign-in', window.location.origin)
      url.searchParams.set('return', ret)
      try {
        await sendSignInLinkToEmail(auth, email, {
          url: url.toString(),
          handleCodeInApp: true,
        })
        window.localStorage.setItem('oriz_email_for_sign_in', email)
        show(`We sent a sign-in link to ${email}. Open it on this device.`, 'success')
      } catch (err) {
        const e = err as { message?: string }
        show(e.message ?? 'Could not send sign-in link.', 'error')
      }
    })

    // Tier-gated "more options" reveal
    const moreBtn = document.getElementById('more-btn') as HTMLButtonElement
    const gated = document.getElementById('gated') as HTMLDivElement
    const reveal = () => { gated.dataset.open = 'true'; moreBtn.style.display = 'none' }
    if (phoneFlag) reveal()
    moreBtn.addEventListener('click', reveal)

    // Phone OTP (Pro+ gated — UI hidden by default)
    let confirmation: ConfirmationResult | null = null
    const phoneForm = document.getElementById('phone-form') as HTMLFormElement
    phoneForm.addEventListener('submit', async (e) => {
      e.preventDefault()
      clear()
      const phone = (document.getElementById('phone') as HTMLInputElement).value.trim()
      if (!phone) return show('Enter your phone number.', 'error')
      try {
        if (!confirmation) {
          const verifier = new RecaptchaVerifier(auth, 'recaptcha-container', {
            size: 'invisible',
          })
          confirmation = await signInWithPhoneNumber(auth, phone, verifier)
          const code = window.prompt('Enter the 6-digit code we just texted:')
          if (!code) return
          await confirmation.confirm(code)
        }
      } catch (err) {
        const e = err as { message?: string }
        show(e.message ?? 'Phone sign-in failed.', 'error')
      }
    })
  </script>
</BaseLayout>
