---
import BaseLayout from '~/layouts/BaseLayout.astro'
import Brand from '~/components/Brand.astro'
---
<BaseLayout title="Reset password · oriz">
  <section class="card">
    <Brand />
    <h1>Reset password</h1>
    <p class="sub">
      oriz uses passwordless sign-in (email links + OAuth + phone). There are no
      passwords to reset. Use the same provider you signed up with.
    </p>
    <a class="btn btn-primary" href="/sign-in">
      <span class="label">Back to sign in</span>
    </a>
    <p class="muted" style="margin-top:1rem;">
      Lost access to your email? Use a different provider, or contact support.
    </p>
  </section>
</BaseLayout>
