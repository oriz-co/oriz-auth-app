---
import BaseLayout from '~/layouts/BaseLayout.astro'
import Brand from '~/components/Brand.astro'
---
<BaseLayout title="Finishing sign-in · oriz">
  <section class="card center-text">
    <Brand />
    <h1>Finishing sign-in…</h1>
    <p class="sub" id="msg">Verifying the link from your email.</p>
    <div id="banner" class="banner" data-kind="info"></div>
  </section>

  <script>
    import {
      isSignInWithEmailLink,
      signInWithEmailLink,
    } from 'firebase/auth'
    import { getFirebase, startCookieSync, safeReturnURL } from '~/lib/firebase'

    const { auth } = getFirebase()
    startCookieSync()

    const banner = document.getElementById('banner') as HTMLDivElement
    const show = (msg: string, kind: 'info' | 'error' | 'success' = 'info') => {
      banner.textContent = msg
      banner.dataset.kind = kind
      banner.style.display = 'block'
    }

    const params = new URLSearchParams(window.location.search)
    const ret = params.get('return') || '/account'

    ;(async () => {
      if (!isSignInWithEmailLink(auth, window.location.href)) {
        show('This link is not a valid sign-in link.', 'error')
        return
      }
      let email = window.localStorage.getItem('oriz_email_for_sign_in')
      if (!email) {
        email = window.prompt('Confirm the email you signed in with:')
      }
      if (!email) return show('Email confirmation cancelled.', 'error')
      try {
        await signInWithEmailLink(auth, email, window.location.href)
        window.localStorage.removeItem('oriz_email_for_sign_in')
        window.location.replace(safeReturnURL(ret))
      } catch (err) {
        const e = err as { message?: string }
        show(e.message ?? 'Sign-in failed.', 'error')
      }
    })()
  </script>
</BaseLayout>
